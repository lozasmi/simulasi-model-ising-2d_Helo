# SYSTEM SIMULATION CODE: 2D ISING MODEL
# =====================================================================
import numpy as np
import matplotlib.pyplot as plt
import random

# Apply professional academic plotting style
plt.style.use('seaborn-v0_8-darkgrid')

def metropolis_step(grid, T):
    """Executes a single trial flip attempt using the Metropolis algorithm."""
    N = grid.shape[0]
    # Step 2: Randomly select a spin coordinate
    x, y = random.randint(0, N-1), random.randint(0, N-1)
    
    # Calculate the sum of 4 nearest neighbors with Periodic Boundary Conditions (%)
    s_neighbors = (
        grid[(x+1)%N, y] +
        grid[(x-1)%N, y] +
        grid[x, (y+1)%N] +
        grid[x, (y-1)%N]
    )
    
    # Step 3: Compute the local energy change
    delta_E = 2 * grid[x, y] * s_neighbors
    
    # Step 4: Evaluate the Metropolis Criterion
    if delta_E <= 0 or random.random() < np.exp(-delta_E / T):
        grid[x, y] *= -1  # Accept the spin flip
        
    return grid

def run_simulation(N=20, temp=1.0, n_steps=200000):
    """Runs the full Monte Carlo simulation starting from a disordered Hot Start."""
    # Step 1: Initialize system with a Hot Start configuration
    grid = np.random.choice([-1, 1], size=(N, N))
    magnetization_history = []
    
    for step in range(n_steps):
        grid = metropolis_step(grid, temp)
        
        # Sample average magnetization data every 100 steps for efficiency
        if step % 100 == 0:
            magnetization = np.mean(grid)
            magnetization_history.append(magnetization)
            
    return grid, magnetization_history

# --- Main Simulation Execution and Visual Grid Setup ---
if __name__ == "__main__":
    GRID_SIZE = 20
    MONTE_CARLO_STEPS = 200000
    temperatures = [1.0, 2.27, 4.0]

    # Create a 2x3 subplot matrix for the three case studies
    fig, axes = plt.subplots(2, len(temperatures), figsize=(15, 10))
    fig.suptitle("2D Ising Model Simulation: Thermal Phase Transitions", fontsize=16, fontweight='bold')

    for i, T in enumerate(temperatures):
        print(f"Running simulation for Case T = {T}...")
        final_grid, M_history = run_simulation(N=GRID_SIZE, temp=T, n_steps=MONTE_CARLO_STEPS)
        
        # Row 1: Visual Spatial Grid Configurations
        ax_grid = axes[0, i]
        ax_grid.imshow(final_grid, cmap='binary', vmin=-1, vmax=1)
        ax_grid.set_title(f"Final Grid Configuration (T = {T})", fontsize=12, fontweight='bold')
        ax_grid.axis('off')
        
        # Row 2: Average Magnetization Progress Curves
        ax_mag = axes[1, i]
        ax_mag.plot(M_history, color='teal', alpha=0.8, linewidth=1.2)
        ax_mag.axhline(1.0, color='red', linestyle='--', alpha=0.5)
        ax_mag.axhline(0.0, color='black', linestyle=':', alpha=0.5)
        ax_mag.axhline(-1.0, color='red', linestyle='--', alpha=0.5)
        
        ax_mag.set_title(f"Magnetization History (T = {T})", fontsize=12)
        ax_mag.set_xlabel("Monte Carlo Steps (x100)")
        ax_mag.set_ylabel("Average Magnetization (M)")
        ax_mag.set_ylim(-1.1, 1.1)
        ax_mag.grid(True, linestyle='--', alpha=0.5)

    plt.tight_layout(rect=[0, 0, 1, 0.95])
    plt.show()
